{
  // TupleBase dev config — safe to commit: secrets are never stored here.
  // Start databases with: npm run db:start -- <engine> && npm run db:seed -- <engine>  (postgres, redis, dynamo) (pg password: tuplebase)
  "version": 1,
  "groups": {
    "local": {
      "local-dynamo": {
        "adapter": "dynamodb",
        "region": "local",
        "endpoint": "http://localhost:8000"
      },
      "local-redis": {
        "adapter": "redis",
        "host": "localhost",
        "port": 6379
      },
      "local-pg": {
        "adapter": "postgres",
        "host": "localhost",
        "port": 5432,
        "database": "tuplebase",
        "user": "tuplebase"
      },
      "local-mysql": {
        "adapter": "mysql",
        "host": "localhost",
        "port": 3306,
        "database": "tuplebase",
        "user": "tuplebase"
      },
      "local-mariadb": {
        "adapter": "mysql",
        "host": "localhost",
        "port": 3307,
        "database": "tuplebase",
        "user": "tuplebase"
      },
      "local-sqlite": {
        "adapter": "sqlite",
        "path": "../seed/sqlite/demo.sqlite"
      },
      "local-clickhouse": {
        "adapter": "clickhouse",
        "host": "localhost",
        "port": 8123,
        "database": "tuplebase",
        "user": "default"
      },
      "local-mssql": {
        "adapter": "mssql",
        "host": "localhost",
        "port": 1433,
        "database": "tuplebase",
        "user": "sa"
      },
      "local-cassandra": {
        "adapter": "cassandra",
        "host": "localhost",
        "port": 9042,
        "datacenter": "datacenter1",
        "keyspace": "tuplebase"
      },
      "local-neo4j": {
        "adapter": "neo4j",
        "host": "localhost",
        "port": 7687,
        "database": "neo4j",
        "user": "neo4j"
      },
      "local-mongodb": {
        "adapter": "mongodb",
        "host": "localhost",
        "port": 27017,
        "database": "tuplebase"
      },
      "local-elasticsearch": {
        "adapter": "elasticsearch",
        "host": "localhost",
        "port": 9200
      },
      "local-kafka": {
        "adapter": "kafka",
        "host": "localhost",
        "port": 9092
      },
      "Test": {
        "adapter": "dynamodb",
        "region": "local",
        "profile": "local",
        "endpoint": "localhost:8000"
      }
    }
  }
}
