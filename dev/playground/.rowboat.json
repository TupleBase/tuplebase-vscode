{
  // Rowboat dev config — safe to commit: secrets are never stored here.
  // Start databases with: npm run db:postgres + db:redis + db:dynamo (pg password: rowboat)
  "version": 1,
  "groups": {
    "local": {
      "local-dynamo": {
        "adapter": "dynamodb",
        "region": "local",
        "endpoint": "http://localhost:8000"
      },
      "local-redis": {
        "adapter": "redis",
        "host": "localhost",
        "port": 6379
      },
      "local-pg": {
        "adapter": "postgres",
        "host": "localhost",
        "port": 5432,
        "database": "rowboat",
        "user": "rowboat"
      }
    },
    "Test": {
      "Test": {
        "adapter": "dynamodb",
        "region": "local",
        "profile": "local",
        "endpoint": "localhost:8000"
      }
    }
  }
}
