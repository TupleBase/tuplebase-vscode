{
  // Rowboat dev config — safe to commit: secrets are never stored here.
  // Start databases with: npm run db:postgres + db:redis + db:dynamo (pg password: rowboat)
  "version": 1,
  "groups": {
    "local": {
      "local-dynamo": {
        "adapter": "dynamodb",
        "region": "local",
        "endpoint": "http://localhost:8000"
      },
      "local-redis": {
        "adapter": "redis",
        "host": "localhost",
        "port": 6379
      },
      "local-pg": {
        "adapter": "postgres",
        "host": "localhost",
        "port": 5432,
        "database": "rowboat",
        "user": "rowboat"
      },
      "local-mysql": {
        "adapter": "mysql",
        "host": "localhost",
        "port": 3306,
        "database": "rowboat",
        "user": "rowboat"
      },
      "local-mariadb": {
        "adapter": "mysql",
        "host": "localhost",
        "port": 3307,
        "database": "rowboat",
        "user": "rowboat"
      },
      "local-sqlite": {
        "adapter": "sqlite",
        "path": "dev/seed/sqlite/demo.sqlite"
      },
      "local-clickhouse": {
        "adapter": "clickhouse",
        "host": "localhost",
        "port": 8123,
        "database": "rowboat",
        "user": "default"
      },
      "local-mssql": {
        "adapter": "mssql",
        "host": "localhost",
        "port": 1433,
        "database": "rowboat",
        "user": "sa"
      },
      "local-cassandra": {
        "adapter": "cassandra",
        "host": "localhost",
        "port": 9042,
        "datacenter": "datacenter1",
        "keyspace": "rowboat"
      },
      "local-neo4j": {
        "adapter": "neo4j",
        "host": "localhost",
        "port": 7687,
        "database": "neo4j",
        "user": "neo4j"
      }
    },
    "Test": {
      "Test": {
        "adapter": "dynamodb",
        "region": "local",
        "profile": "local",
        "endpoint": "localhost:8000"
      }
    }
  }
}
