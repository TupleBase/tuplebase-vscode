{
  "name": "rowboat",
  "displayName": "Rowboat",
  "description": "Paddle through your rows. Query Postgres, Redis and DynamoDB from VS Code.",
  "version": "0.1.0",
  "publisher": "felicegeracitano",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FeliceGeracitano/rowboat"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "postgres",
    "redis",
    "dynamodb",
    "sql",
    "database"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/.rowboat.json"
  ],
  "contributes": {
    "languages": [
      {
        "id": "jsonc",
        "filenames": [
          ".rowboat.json"
        ]
      },
      {
        "id": "redis",
        "aliases": [
          "Redis"
        ],
        "extensions": [
          ".redis"
        ],
        "configuration": "./language-configuration-redis.json"
      }
    ],
    "grammars": [
      {
        "language": "redis",
        "scopeName": "source.redis",
        "path": "./syntaxes/redis.tmLanguage.json"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": ".rowboat.json",
        "url": "./schemas/rowboat.schema.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rowboat",
          "title": "Rowboat",
          "icon": "media/rowboat.svg"
        }
      ],
      "panel": [
        {
          "id": "rowboat-panel",
          "title": "Rowboat Results",
          "icon": "media/rowboat.svg"
        }
      ]
    },
    "views": {
      "rowboat": [
        {
          "id": "rowboat.explorer",
          "name": "Explorer",
          "icon": "media/rowboat.svg"
        },
        {
          "id": "rowboat.history",
          "name": "History",
          "icon": "media/rowboat.svg"
        }
      ],
      "rowboat-panel": [
        {
          "id": "rowboat.results",
          "type": "webview",
          "name": "Results"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "rowboat.explorer",
        "contents": "No .rowboat.json found in this workspace.\n[Create Config](command:rowboat.createConfig)"
      }
    ],
    "commands": [
      {
        "command": "rowboat.runQuery",
        "title": "Run Query (statement at cursor or selection)",
        "category": "Rowboat",
        "icon": "$(play)"
      },
      {
        "command": "rowboat.runFile",
        "title": "Run All Statements (whole file or selection)",
        "category": "Rowboat",
        "icon": "$(run-all)"
      },
      {
        "command": "rowboat.addGroup",
        "title": "New Group",
        "category": "Rowboat",
        "icon": "$(new-folder)"
      },
      {
        "command": "rowboat.addConnection",
        "title": "New Connection",
        "category": "Rowboat",
        "icon": "$(add)"
      },
      {
        "command": "rowboat.renameGroup",
        "title": "Rename Group",
        "category": "Rowboat"
      },
      {
        "command": "rowboat.deleteGroup",
        "title": "Delete Group",
        "category": "Rowboat",
        "icon": "$(trash)"
      },
      {
        "command": "rowboat.editConnection",
        "title": "Edit Connection",
        "category": "Rowboat",
        "icon": "$(edit)"
      },
      {
        "command": "rowboat.removeConnection",
        "title": "Remove Connection",
        "category": "Rowboat",
        "icon": "$(trash)"
      },
      {
        "command": "rowboat.newQuery",
        "title": "New Query Scratch (pick engine)",
        "category": "Rowboat",
        "icon": "$(file-code)"
      },
      {
        "command": "rowboat.refreshExplorer",
        "title": "Refresh Explorer",
        "category": "Rowboat",
        "icon": "$(refresh)"
      },
      {
        "command": "rowboat.clearCredentials",
        "title": "Clear Stored Credentials",
        "category": "Rowboat"
      },
      {
        "command": "rowboat.createConfig",
        "title": "Create Config File",
        "category": "Rowboat"
      },
      {
        "command": "rowboat.connect",
        "title": "Connect",
        "category": "Rowboat",
        "icon": "$(plug)"
      },
      {
        "command": "rowboat.disconnect",
        "title": "Disconnect",
        "category": "Rowboat",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "rowboat.newQueryOnConnection",
        "title": "New Query on This Connection",
        "category": "Rowboat",
        "icon": "$(file-code)"
      },
      {
        "command": "rowboat.selectConnectionForFile",
        "title": "Select Connection for Current File",
        "category": "Rowboat"
      },
      {
        "command": "rowboat.history.rerun",
        "title": "Rerun From History",
        "category": "Rowboat"
      },
      {
        "command": "rowboat.history.clear",
        "title": "Clear Query History",
        "category": "Rowboat",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "rowboat.runQuery",
          "when": "resourceLangId == sql || resourceLangId == redis",
          "group": "navigation@1"
        },
        {
          "command": "rowboat.runFile",
          "when": "resourceLangId == sql || resourceLangId == redis",
          "group": "navigation@2"
        }
      ],
      "view/title": [
        {
          "command": "rowboat.addGroup",
          "when": "view == rowboat.explorer",
          "group": "navigation@1"
        },
        {
          "command": "rowboat.refreshExplorer",
          "when": "view == rowboat.explorer",
          "group": "navigation@2"
        },
        {
          "command": "rowboat.history.clear",
          "when": "view == rowboat.history",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "rowboat.addConnection",
          "when": "view == rowboat.explorer && viewItem == rowboat.group",
          "group": "inline@1"
        },
        {
          "command": "rowboat.addConnection",
          "when": "view == rowboat.explorer && viewItem == rowboat.group",
          "group": "1_modify@1"
        },
        {
          "command": "rowboat.renameGroup",
          "when": "view == rowboat.explorer && viewItem == rowboat.group",
          "group": "1_modify@2"
        },
        {
          "command": "rowboat.deleteGroup",
          "when": "view == rowboat.explorer && viewItem == rowboat.group",
          "group": "1_modify@3"
        },
        {
          "command": "rowboat.editConnection",
          "when": "view == rowboat.explorer && (viewItem == rowboat.connection.connected || viewItem == rowboat.connection.disconnected)",
          "group": "1_modify@8"
        },
        {
          "command": "rowboat.removeConnection",
          "when": "view == rowboat.explorer && (viewItem == rowboat.connection.connected || viewItem == rowboat.connection.disconnected)",
          "group": "1_modify@9"
        },
        {
          "command": "rowboat.connect",
          "when": "view == rowboat.explorer && viewItem == rowboat.connection.disconnected",
          "group": "inline@1"
        },
        {
          "command": "rowboat.newQueryOnConnection",
          "when": "view == rowboat.explorer && viewItem == rowboat.connection.connected",
          "group": "inline@1"
        },
        {
          "command": "rowboat.newQueryOnConnection",
          "when": "view == rowboat.explorer && viewItem == rowboat.connection.connected",
          "group": "0_open@1"
        },
        {
          "command": "rowboat.newQueryOnConnection",
          "when": "view == rowboat.explorer && viewItem == rowboat.connection.disconnected",
          "group": "0_open@1"
        },
        {
          "command": "rowboat.disconnect",
          "when": "view == rowboat.explorer && viewItem == rowboat.connection.connected",
          "group": "inline@2"
        },
        {
          "command": "rowboat.connect",
          "when": "view == rowboat.explorer && viewItem == rowboat.connection.disconnected"
        },
        {
          "command": "rowboat.disconnect",
          "when": "view == rowboat.explorer && viewItem == rowboat.connection.connected"
        },
        {
          "command": "rowboat.history.rerun",
          "when": "view == rowboat.history"
        }
      ],
      "commandPalette": [
        {
          "command": "rowboat.selectConnectionForFile",
          "when": "editorLangId == sql || editorLangId == redis"
        },
        {
          "command": "rowboat.connect",
          "when": "false"
        },
        {
          "command": "rowboat.disconnect",
          "when": "false"
        },
        {
          "command": "rowboat.newQueryOnConnection",
          "when": "false"
        },
        {
          "command": "rowboat.addConnection",
          "when": "false"
        },
        {
          "command": "rowboat.renameGroup",
          "when": "false"
        },
        {
          "command": "rowboat.deleteGroup",
          "when": "false"
        },
        {
          "command": "rowboat.editConnection",
          "when": "false"
        },
        {
          "command": "rowboat.removeConnection",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "rowboat.runQuery",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && (resourceLangId == sql || resourceLangId == redis)"
      },
      {
        "command": "rowboat.runFile",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "editorTextFocus && (resourceLangId == sql || resourceLangId == redis)"
      }
    ],
    "configurationDefaults": {
      "workbench.hover.delay": 200
    },
    "configuration": {
      "title": "Rowboat",
      "properties": {
        "rowboat.queryTimeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1,
          "description": "Maximum time in milliseconds for a query before Rowboat cancels it."
        },
        "rowboat.resultsPageSize": {
          "type": "number",
          "default": 500,
          "minimum": 1,
          "description": "How many rows a query fetches per run (capped by rowboat.maxRows)."
        },
        "rowboat.maxRows": {
          "type": "number",
          "default": 5000,
          "minimum": 1,
          "description": "Hard upper bound on rows fetched in a single run."
        }
      }
    }
  },
  "scripts": {
    "build": "npm run gen:schema && node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "gen:schema": "node scripts/gen-schema.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "db:postgres": "docker compose --profile postgres up -d",
    "db:redis": "docker compose --profile redis up -d --wait && npm run db:seed:redis",
    "db:dynamo": "docker compose --profile dynamo up -d && npm run db:seed:dynamo",
    "db:seed:redis": "grep -v '^#' dev/seed/redis/seed.redis | docker compose exec -T redis redis-cli",
    "db:seed:dynamo": "node dev/seed/dynamo/seed.mjs",
    "db:seed": "npm run db:seed:redis && npm run db:seed:dynamo",
    "db:seed:big:postgres": "docker compose exec -T postgres psql -U rowboat -d rowboat < dev/seed/postgres/big.sql",
    "db:seed:big:redis": "node -e \"for(let i=1;i<=5000;i++)console.log('SET pagedemo:'+i+' value-'+i)\" | docker compose exec -T redis redis-cli",
    "db:seed:big:dynamo": "node dev/seed/dynamo/big.mjs",
    "db:seed:big": "npm run db:seed:big:postgres && npm run db:seed:big:redis && npm run db:seed:big:dynamo",
    "db:all": "docker compose --profile all up -d --wait && npm run db:seed",
    "db:down": "docker compose --profile all down",
    "test:vscode": "npm run build && vscode-test"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@types/ssh2": "^1.15.5",
    "@types/tabulator-tables": "^6.3.5",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1080.0",
    "@aws-sdk/credential-providers": "^3.1080.0",
    "@aws-sdk/lib-dynamodb": "^3.1080.0",
    "@redis/client": "^6.1.0",
    "jsonc-parser": "^3.3.1",
    "pg": "^8.22.0",
    "ssh2": "^1.17.0",
    "tabulator-tables": "^6.5.2"
  }
}
