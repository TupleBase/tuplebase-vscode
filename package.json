{
  "name": "rowboat",
  "displayName": "Rowboat",
  "description": "Paddle through your rows. Query Postgres, Redis and DynamoDB from VS Code.",
  "version": "0.1.0",
  "publisher": "felicegeracitano",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FeliceGeracitano/rowboat"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "postgres",
    "redis",
    "dynamodb",
    "sql",
    "database"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/.rowboat.json"
  ],
  "contributes": {
    "languages": [
      {
        "id": "jsonc",
        "filenames": [
          ".rowboat.json"
        ]
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": ".rowboat.json",
        "url": "./schemas/rowboat.schema.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rowboat",
          "title": "Rowboat",
          "icon": "media/rowboat.svg"
        }
      ],
      "panel": [
        {
          "id": "rowboat-panel",
          "title": "Rowboat Results",
          "icon": "media/rowboat.svg"
        }
      ]
    },
    "views": {
      "rowboat": [
        {
          "id": "rowboat.explorer",
          "name": "Explorer",
          "icon": "media/rowboat.svg"
        }
      ],
      "rowboat-panel": [
        {
          "id": "rowboat.results",
          "type": "webview",
          "name": "Results"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "rowboat.explorer",
        "contents": "No .rowboat.json found in this workspace.\n[Create Config](command:rowboat.createConfig)"
      }
    ],
    "commands": [
      {
        "command": "rowboat.runQuery",
        "title": "Rowboat: Run Query",
        "icon": "$(play)"
      },
      {
        "command": "rowboat.selectEnvironment",
        "title": "Rowboat: Select Environment"
      },
      {
        "command": "rowboat.refreshExplorer",
        "title": "Rowboat: Refresh Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "rowboat.clearCredentials",
        "title": "Rowboat: Clear Stored Credentials"
      },
      {
        "command": "rowboat.createConfig",
        "title": "Rowboat: Create Config File"
      },
      {
        "command": "rowboat.disconnect",
        "title": "Rowboat: Disconnect"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "rowboat.runQuery",
          "when": "resourceLangId == sql",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "rowboat.refreshExplorer",
          "when": "view == rowboat.explorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "rowboat.disconnect",
          "when": "view == rowboat.explorer && viewItem == rowboat.connection"
        }
      ]
    },
    "keybindings": [
      {
        "command": "rowboat.runQuery",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && resourceLangId == sql"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "db:postgres": "docker compose --profile postgres up -d",
    "db:all": "docker compose --profile all up -d",
    "db:down": "docker compose --profile all down",
    "test:vscode": "npm run build && vscode-test"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@types/tabulator-tables": "^6.3.5",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "pg": "^8.22.0",
    "tabulator-tables": "^6.5.2"
  }
}
